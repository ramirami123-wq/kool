      "settings": {
        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\"/>\n\n<style>\n  .faq-section {\n    width: 100%;\n    max-width: 600px;\n    margin: 0 auto;\n    padding: 40px 20px 56px;\n    font-family: 'Nunito', sans-serif;\n    background: #ffffff;\n    box-sizing: border-box;\n  }\n\n  /* Title */\n  .faq-header {\n    text-align: center;\n    margin-bottom: 6px;\n  }\n  .faq-title {\n    font-size: clamp(1.6rem, 6vw, 2.1rem);\n    font-weight: 900;\n    color: #1a1a2e;\n    margin: 0 0 4px;\n    display: inline;\n  }\n  .faq-title-heart {\n    display: inline-block;\n    margin-left: 6px;\n    vertical-align: middle;\n  }\n  .faq-title-heart svg { width: 22px; height: 22px; }\n\n  .faq-subtitle {\n    font-size: clamp(0.82rem, 3vw, 0.95rem);\n    font-weight: 600;\n    color: #888;\n    margin: 4px 0 20px;\n    font-style: italic;\n  }\n\n  /* Search bar */\n  .faq-search-wrap {\n    position: relative;\n    margin-bottom: 28px;\n  }\n  .faq-search-icon {\n    position: absolute;\n    left: 14px; top: 50%;\n    transform: translateY(-50%);\n    width: 16px; height: 16px;\n    color: #bbb;\n    pointer-events: none;\n  }\n  .faq-search {\n    width: 100%;\n    padding: 12px 16px 12px 40px;\n    border: 1.5px solid #e8e0d8;\n    border-radius: 30px;\n    background: #fff;\n    font-family: 'Nunito', sans-serif;\n    font-size: 0.88rem;\n    font-weight: 600;\n    color: #444;\n    outline: none;\n    box-sizing: border-box;\n    transition: border-color 0.2s;\n  }\n  .faq-search::placeholder { color: #bbb; }\n  .faq-search:focus { border-color: #e87c7c; }\n\n  /* Category block */\n  .faq-category { margin-bottom: 6px; }\n\n  /* Category header row */\n  .faq-cat-header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 14px 4px;\n    cursor: pointer;\n    border-bottom: 1.5px solid #ede8e0;\n    gap: 10px;\n  }\n  .faq-cat-left {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n  .faq-cat-icon {\n    width: 36px; height: 36px;\n    border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    flex-shrink: 0;\n  }\n  .faq-cat-icon svg { width: 18px; height: 18px; }\n\n  .faq-ic-product   { background: #fde8e8; }\n  .faq-ic-bluetooth { background: #e8f0fd; }\n  .faq-ic-shipping  { background: #fde8e8; }\n  .faq-ic-returns   { background: #e8f0fd; }\n\n  .faq-cat-name {\n    font-size: clamp(1rem, 3.5vw, 1.1rem);\n    font-weight: 800;\n    color: #1a1a2e;\n  }\n\n  .faq-cat-chevron {\n    width: 20px; height: 20px;\n    color: #5c82e0;\n    flex-shrink: 0;\n    transition: transform 0.3s ease;\n  }\n  .faq-category.open .faq-cat-chevron {\n    transform: rotate(180deg);\n  }\n\n  /* Questions list */\n  .faq-questions {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.35s ease;\n  }\n  .faq-category.open .faq-questions {\n    max-height: 600px;\n  }\n\n  /* Single question row */\n  .faq-item {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 13px 4px;\n    border-bottom: 1px solid #f0ebe3;\n    cursor: pointer;\n    gap: 10px;\n  }\n  .faq-item:last-child { border-bottom: none; }\n\n  .faq-q {\n    font-size: clamp(0.82rem, 3vw, 0.92rem);\n    font-weight: 600;\n    color: #333;\n    margin: 0;\n    text-align: left;\n    flex: 1;\n    transition: color 0.2s;\n  }\n  .faq-item:hover .faq-q { color: #e87c7c; }\n\n  .faq-item-chevron {\n    width: 16px; height: 16px;\n    color: #5c82e0;\n    flex-shrink: 0;\n    transition: transform 0.3s;\n  }\n  .faq-item.open .faq-item-chevron { transform: rotate(180deg); }\n\n  /* Answer */\n  .faq-answer {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.3s ease;\n    background: #fff8f8;\n    border-radius: 0 0 8px 8px;\n  }\n  .faq-item.open + .faq-answer { max-height: 200px; }\n  .faq-answer p {\n    margin: 0;\n    padding: 10px 8px 14px;\n    font-size: 0.85rem;\n    font-weight: 600;\n    color: #666;\n    line-height: 1.6;\n    text-align: left;\n  }\n\n  /* No results */\n  .faq-no-results {\n    text-align: center;\n    padding: 32px 0;\n    font-size: 0.9rem;\n    font-weight: 600;\n    color: #bbb;\n    display: none;\n  }\n</style>\n\n<div class=\"faq-section\" id=\"faqSection\">\n\n  <div class=\"faq-header\">\n    <h2 class=\"faq-title\">Questions, Answered</h2>\n    <span class=\"faq-title-heart\">\n      <svg viewBox=\"0 0 24 24\" fill=\"#e87c7c\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5\n                 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09\n                 C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5\n                 c0 3.78-3.4 6.86-8.55 11.54L12 21.35z\"/>\n      </svg>\n    </span>\n    <p class=\"faq-subtitle\">Everything moms want to know.</p>\n  </div>\n\n  <!-- Search -->\n  <div class=\"faq-search-wrap\">\n    <svg class=\"faq-search-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\">\n      <circle cx=\"11\" cy=\"11\" r=\"7\"/><line x1=\"16.5\" y1=\"16.5\" x2=\"22\" y2=\"22\"/>\n    </svg>\n    <input class=\"faq-search\" id=\"faqSearch\" type=\"text\" placeholder=\"Search for help (e.g. battery, sizing, returns)\" autocomplete=\"off\"/>\n  </div>\n\n  <div id=\"faqList\">\n\n    <!-- Product -->\n    <div class=\"faq-category open\" data-cat=\"product\">\n      <div class=\"faq-cat-header\">\n        <div class=\"faq-cat-left\">\n          <div class=\"faq-cat-icon faq-ic-product\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#e05c5c\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n              <path d=\"M9 18V5l12-2v13\"/><circle cx=\"6\" cy=\"18\" r=\"3\"/><circle cx=\"18\" cy=\"16\" r=\"3\"/>\n            </svg>\n          </div>\n          <span class=\"faq-cat-name\">Product</span>\n        </div>\n        <svg class=\"faq-cat-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg>\n      </div>\n      <div class=\"faq-questions\">\n        <div class=\"faq-item\"><p class=\"faq-q\">Is it comfortable for sleep?</p><svg class=\"faq-item-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg></div>\n        <div class=\"faq-answer\"><p>Yes! The soft cushioned ear cups are designed to be thin and comfortable enough for children to wear while lying down or sleeping.</p></div>\n        <div class=\"faq-item\"><p class=\"faq-q\">Does it fit young kids?</p><svg class=\"faq-item-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg></div>\n        <div class=\"faq-answer\"><p>Absolutely. The headband is fully adjustable to fit kids of all head sizes comfortably and securely.</p></div>\n        <div class=\"faq-item\"><p class=\"faq-q\">What age is it best for?</p><svg class=\"faq-item-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg></div>\n        <div class=\"faq-answer\"><p>We recommend it for children aged 3 and up. It's perfect for toddlers through early school age.</p></div>\n        <div class=\"faq-item\"><p class=\"faq-q\">Is the volume safe for kids?</p><svg class=\"faq-item-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg></div>\n        <div class=\"faq-answer\"><p>Yes! Volume is limited to 85dB — the recommended safe level for children's hearing protection.</p></div>\n      </div>\n    </div>\n\n    <!-- Bluetooth & Charging -->\n    <div class=\"faq-category\" data-cat=\"bluetooth\">\n      <div class=\"faq-cat-header\">\n        <div class=\"faq-cat-left\">\n          <div class=\"faq-cat-icon faq-ic-bluetooth\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#5c82e0\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n              <polyline points=\"6.5 6.5 17.5 17.5 12 23 12 1 17.5 6.5 6.5 17.5\"/>\n            </svg>\n          </div>\n          <span class=\"faq-cat-name\">Bluetooth &amp; Charging</span>\n        </div>\n        <svg class=\"faq-cat-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg>\n      </div>\n      <div class=\"faq-questions\">\n        <div class=\"faq-item\"><p class=\"faq-q\">How do I connect it?</p><svg class=\"faq-item-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg></div>\n        <div class=\"faq-answer\"><p>Turn on Bluetooth on your device, hold the power button for 3 seconds until you hear a pairing tone, then select the headphones from your Bluetooth menu.</p></div>\n        <div class=\"faq-item\"><p class=\"faq-q\">How long does the battery last?</p><svg class=\"faq-item-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg></div>\n        <div class=\"faq-answer\"><p>Up to 20 hours of continuous playtime on a single charge, so it'll last through any trip or bedtime routine.</p></div>\n        <div class=\"faq-item\"><p class=\"faq-q\">How long does it take to charge?</p><svg class=\"faq-item-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg></div>\n        <div class=\"faq-answer\"><p>Approximately 1.5 to 2 hours for a full charge via the included USB-C cable.</p></div>\n        <div class=\"faq-item\"><p class=\"faq-q\">Can I use it while it's charging?</p><svg class=\"faq-item-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg></div>\n        <div class=\"faq-answer\"><p>Yes, you can use the headphones while they're plugged in and charging — no interruptions needed.</p></div>\n      </div>\n    </div>\n\n    <!-- Shipping -->\n    <div class=\"faq-category\" data-cat=\"shipping\">\n      <div class=\"faq-cat-header\">\n        <div class=\"faq-cat-left\">\n          <div class=\"faq-cat-icon faq-ic-shipping\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#e05c5c\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n              <rect x=\"1\" y=\"3\" width=\"15\" height=\"13\" rx=\"1\"/><path d=\"M16 8h4l3 5v3h-7V8z\"/><circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\"/><circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\"/>\n            </svg>\n          </div>\n          <span class=\"faq-cat-name\">Shipping</span>\n        </div>\n        <svg class=\"faq-cat-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg>\n      </div>\n      <div class=\"faq-questions\">\n        <div class=\"faq-item\"><p class=\"faq-q\">Do you ship internationally?</p><svg class=\"faq-item-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg></div>\n        <div class=\"faq-answer\"><p>Yes, we ship to most countries worldwide. Shipping rates and times will vary by destination at checkout.</p></div>\n        <div class=\"faq-item\"><p class=\"faq-q\">How long does shipping take?</p><svg class=\"faq-item-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg></div>\n        <div class=\"faq-answer\"><p>Standard shipping is 5–7 business days. Express shipping (2–3 days) is available at checkout.</p></div>\n        <div class=\"faq-item\"><p class=\"faq-q\">Can I track my order?</p><svg class=\"faq-item-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg></div>\n        <div class=\"faq-answer\"><p>Absolutely! You'll receive a tracking link via email as soon as your order ships.</p></div>\n        <div class=\"faq-item\"><p class=\"faq-q\">Do you offer free shipping?</p><svg class=\"faq-item-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg></div>\n        <div class=\"faq-answer\"><p>Yes! Free standard shipping on all orders over $50 within the US.</p></div>\n      </div>\n    </div>\n\n    <!-- Returns -->\n    <div class=\"faq-category\" data-cat=\"returns\">\n      <div class=\"faq-cat-header\">\n        <div class=\"faq-cat-left\">\n          <div class=\"faq-cat-icon faq-ic-returns\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#5c82e0\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n              <polyline points=\"1 4 1 10 7 10\"/><path d=\"M3.51 15a9 9 0 1 0 .49-4.5\"/>\n            </svg>\n          </div>\n          <span class=\"faq-cat-name\">Returns</span>\n        </div>\n        <svg class=\"faq-cat-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg>\n      </div>\n      <div class=\"faq-questions\">\n        <div class=\"faq-item\"><p class=\"faq-q\">Can I return it?</p><svg class=\"faq-item-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg></div>\n        <div class=\"faq-answer\"><p>Yes, we accept returns on unused items in original packaging within 30 days of delivery.</p></div>\n        <div class=\"faq-item\"><p class=\"faq-q\">What is your return window?</p><svg class=\"faq-item-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg></div>\n        <div class=\"faq-answer\"><p>Our return window is 30 days from the date you received your order.</p></div>\n        <div class=\"faq-item\"><p class=\"faq-q\">Is return shipping free?</p><svg class=\"faq-item-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg></div>\n        <div class=\"faq-answer\"><p>Yes — we provide a prepaid return label for all qualifying returns within the US.</p></div>\n        <div class=\"faq-item\"><p class=\"faq-q\">When will I get my refund?</p><svg class=\"faq-item-chevron\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\"><polyline points=\"6 9 12 15 18 9\"/></svg></div>\n        <div class=\"faq-answer\"><p>Refunds are processed within 3–5 business days of receiving your return and will appear on your original payment method.</p></div>\n      </div>\n    </div>\n\n  </div>\n\n  <p class=\"faq-no-results\" id=\"faqNoResults\">No results found. Try a different keyword!</p>\n</div>\n\n<script>\n(function () {\n\n  /* ── Category toggle ── */\n  document.querySelectorAll('.faq-cat-header').forEach(function (header) {\n    header.addEventListener('click', function () {\n      var cat = header.closest('.faq-category');\n      cat.classList.toggle('open');\n    });\n  });\n\n  /* ── Question accordion ── */\n  document.querySelectorAll('.faq-item').forEach(function (item) {\n    item.addEventListener('click', function () {\n      var answer = item.nextElementSibling;\n      if (!answer || !answer.classList.contains('faq-answer')) return;\n      var isOpen = item.classList.contains('open');\n      /* Close all in same category */\n      var cat = item.closest('.faq-questions');\n      cat.querySelectorAll('.faq-item.open').forEach(function (i) { i.classList.remove('open'); });\n      if (!isOpen) item.classList.add('open');\n    });\n  });\n\n  /* ── Search ── */\n  var searchInput = document.getElementById('faqSearch');\n  var noResults   = document.getElementById('faqNoResults');\n\n  searchInput.addEventListener('input', function () {\n    var query = searchInput.value.toLowerCase().trim();\n    var anyVisible = false;\n\n    document.querySelectorAll('.faq-category').forEach(function (cat) {\n      if (!query) {\n        cat.style.display = '';\n        return;\n      }\n      var catName  = cat.querySelector('.faq-cat-name').textContent.toLowerCase();\n      var items    = cat.querySelectorAll('.faq-item');\n      var catMatch = false;\n\n      items.forEach(function (item) {\n        var text = item.querySelector('.faq-q').textContent.toLowerCase();\n        var match = text.includes(query) || catName.includes(query);\n        item.style.display = match ? '' : 'none';\n        var answer = item.nextElementSibling;\n        if (answer && answer.classList.contains('faq-answer')) {\n          answer.style.display = match ? '' : 'none';\n        }\n        if (match) catMatch = true;\n      });\n\n      cat.style.display = catMatch ? '' : 'none';\n      if (catMatch) {\n        cat.classList.add('open');\n        anyVisible = true;\n      }\n    });\n\n    noResults.style.display = (!query || anyVisible) ? 'none' : 'block';\n\n    if (!query) {\n      document.querySelectorAll('.faq-item, .faq-answer').forEach(function (el) {\n        el.style.display = '';\n      });\n    }\n  });\n\n})();\n</script>",
