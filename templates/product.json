    "custom_liquid_cfcxLt": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "liquid": "<div class=\"kidnest-info-banner\">\n  <div class=\"kidnest-info-item\">\n    <div class=\"kidnest-icon\">\n      <svg viewBox=\"0 0 24 24\"><path d=\"M12 21s-7-4.4-7-11a7 7 0 0 1 14 0c0 6.6-7 11-7 11z\"/><path d=\"M9 10l2 2 4-4\"/></svg>\n    </div>\n    <h3>PREMIUM MATERIAL</h3>\n    <p class=\"kidnest-bold\">Hypoallergenic • Lightweight • Washable</p>\n    <p>Designed for little ones to enjoy music, stories, and calm moments comfortably.</p>\n  </div>\n\n  <div class=\"kidnest-info-item\">\n    <div class=\"kidnest-icon\">\n      <svg viewBox=\"0 0 24 24\"><path d=\"M12 3l8 4v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V7l8-4z\"/><path d=\"M9 12l2 2 4-4\"/></svg>\n    </div>\n    <h3>FULL GUARANTEE</h3>\n    <p class=\"kidnest-bold\">For anytime, anywhere</p>\n    <p>Made to support everyday routines at home, on the go, or during quiet time.</p>\n  </div>\n\n  <div class=\"kidnest-info-item\">\n    <div class=\"kidnest-icon\">\n      <svg viewBox=\"0 0 24 24\"><path d=\"M3 13h18l-2-5H7l-4 5z\"/><path d=\"M5 13v4h2M17 17h2v-4\"/><circle cx=\"7\" cy=\"17\" r=\"2\"/><circle cx=\"17\" cy=\"17\" r=\"2\"/><path d=\"M7 8V5h8v3\"/></svg>\n    </div>\n    <h3>FAST DELIVERY</h3>\n    <p class=\"kidnest-bold\">Delivered in 3-5 business days</p>\n    <p>Delivered safely across Lebanon, straight to your door.</p>\n  </div>\n</div>\n\n<style>\n.kidnest-info-banner {\n  width: 100%;\n  background: #fffff;\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  padding: 0 20px;\n}\n\n.kidnest-info-item {\n  text-align: center;\n  padding: 0 35px;\n  color: #0B61CD;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n}\n\n.kidnest-info-item:not(:last-child) {\n  border-right: 1px solid #0B61CD;\n}\n\n.kidnest-icon {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n}\n\n.kidnest-icon svg {\n  width: 34px;\n  height: 34px;\n  margin-bottom: 20px;\n  stroke: #0B61CD;\n  fill: none;\n  stroke-width: 1.6;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n.kidnest-info-item h3 {\n  margin: 0 0 12px;\n  font-size: 24px;\n  font-weight: 500;\n  letter-spacing: 1.2px;\n  color: #0B61CD;\n}\n\n.kidnest-info-item p {\n  margin: 0 0 22px;\n  font-size: 15px;\n  line-height: 1.5;\n  color: #0B61CD;\n}\n\n.kidnest-info-item p:last-child {\n  margin-bottom: 0;\n}\n\n.kidnest-bold {\n  font-weight: 700;\n}\n\n@media screen and (max-width: 749px) {\n  .kidnest-info-banner {\n    grid-template-columns: 1fr;\n    padding: 0 18px;\n    gap: 2;\n  }\n\n  .kidnest-info-item {\n    padding: 0 10px 28px;\n  }\n\n  .kidnest-info-item:not(:last-child) {\n    border-right: none;\n    border-bottom: 1px solid #0B61CD;\n  }\n\n  .kidnest-info-item h3 {\n    font-size: 20px;\n  }\n}\n</style>",
