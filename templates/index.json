      "settings": {
        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap\" rel=\"stylesheet\"/>\n\n<style>\n  .etu-section {\n    width: 100%;\n    max-width: 100%;\n    margin: 0 auto;\n    padding: 40px 24px 0;\n    text-align: center;\n    font-family: 'Nunito', sans-serif;\n    background: #ffffff;\n  }\n\n  .etu-title {\n    font-size: clamp(1.8rem, 5vw, 2.4rem);\n    font-weight: 800;\n    color: #1e1e1e;\n    margin-bottom: 20px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 6px;\n    white-space: nowrap;\n  }\n\n  .etu-heart {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    line-height: 1;\n  }\n\n  .etu-heart svg {\n    width: 20px;\n    height: 24px;\n  }\n\n  .etu-slider-wrapper {\n    overflow: visible;\n    width: 100%;\n  }\n\n  .etu-row {\n    display: flex;\n    align-items: flex-start;\n    justify-content: space-between;\n    gap: 0;\n    flex-wrap: nowrap;\n    width: 100%;\n  }\n\n  .etu-step {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 16px;\n    flex: 1;\n    max-width: none;\n  }\n\n  .etu-badge {\n    width: 32px;\n    height: 32px;\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 0.9rem;\n    font-weight: 800;\n    color: #fff;\n    flex-shrink: 0;\n    margin-bottom: 1px;\n  }\n\n  .etu-badge-1 { background: #e87c7c; }\n  .etu-badge-2 { background: #5c82e0; }\n  .etu-badge-3 { background: #c8a8d8; }\n\n  .etu-circle {\n    width: clamp(90px, 16vw, 120px);\n    height: clamp(90px, 16vw, 120px);\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n\n  .etu-circle svg {\n    width: 55%;\n    height: 55%;\n  }\n\n  .etu-circle-1 { background: #fff; border: 2px solid #e8e0d8; }\n  .etu-circle-2 { background: #fff; border: 2px solid #e8e0d8; }\n  .etu-circle-3 { background: #f0e8f0; border: 3px solid #e0d0e8; overflow: hidden; }\n  .etu-circle-3 svg { width: 70%; height: 70%; }\n\n  .etu-step-title {\n    font-size: clamp(0.95rem, 3vw, 1.05rem);\n    font-weight: 800;\n    color: #1e1e1e;\n    margin: 0;\n  }\n\n  .etu-step-desc {\n    font-size: clamp(0.75rem, 2.5vw, 0.82rem);\n    font-weight: 600;\n    color: #777;\n    line-height: 1.5;\n    margin: 0;\n    max-width: 160px;\n  }\n\n  .etu-arrow {\n    display: flex;\n    align-items: center;\n    padding: 0 8px;\n    margin-top: clamp(60px, 10vw, 80px);\n    flex-shrink: 0;\n  }\n\n  .etu-arrow svg {\n    width: clamp(28px, 5vw, 40px);\n    height: 16px;\n  }\n\n  .etu-dots {\n    display: none;\n  }\n\n  @media (max-width: 520px) {\n    .etu-section {\n      padding: 10px 0px 0;\n    }\n\n    .etu-title {\n      font-size: 1.75rem;\n      margin-bottom: 28px;\n      gap: 5px;\n    }\n\n    .etu-row {\n      justify-content: center;\n      align-items: flex-start;\n      gap: 0;\n      flex-wrap: nowrap;\n      transform: none !important;\n    }\n\n    .etu-step {\n      flex: 1;\n      min-width: 0;\n      max-width: 33.33%;\n      padding: 0 4px;\n      box-sizing: border-box;\n      gap: 10px;\n    }\n\n    .etu-badge {\n      width: 24px;\n      height: 24px;\n      font-size: 0.72rem;\n    }\n\n    .etu-circle {\n      width: 72px;\n      height: 72px;\n    }\n\n    .etu-step-title {\n      font-size: 0.75rem;\n      line-height: 1.2;\n    }\n\n    .etu-step-desc {\n      font-size: 0.62rem;\n      line-height: 1.35;\n      max-width: 95px;\n    }\n\n    .etu-arrow {\n      display: none;\n    }\n\n    .etu-dots {\n      display: none;\n    }\n  }\n</style>\n\n<div class=\"etu-section\">\n  <h2 class=\"etu-title\">\n    Easy To Use\n    <span class=\"etu-heart\">\n      <svg viewBox=\"0 0 24 24\" fill=\"#e87c7c\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5\n                 2 5.42 4.42 3 7.