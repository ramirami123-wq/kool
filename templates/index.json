      "settings": {
        "liquid": "<style>\n  .mom-moments-section {\n    width: 100vw;\n    max-width: none;\n    margin-left: calc(50% - 50vw);\n    margin-right: calc(50% - 50vw);\n    background: #ffffff;\n    padding: 0 0px 24px;\n    text-align: center;\n    font-family: 'Nunito', sans-serif;\n  }\n\n  .mom-moments-title {\n    font-size: clamp(1.65rem, 5vw, 2.1rem);\n    font-weight: 800;\n    color: #2b2b2b;\n    letter-spacing: -0.01em;\n    margin-bottom: 28px;\n    line-height: 1.2;\n    white-space: nowrap;\n  }\n\n  .mom-moments-heart {\n    display: inline-block;\n    margin-left: 4px;\n    width: 12px;\n    height: 12px;\n    vertical-align: middle;\n  }\n\n  .mom-moments-heart svg {\n    width: 12px;\n    height: 12px;\n  }\n\n  .mom-moments-row {\n    display: flex;\n    flex-wrap: wrap;\n    justify-content: center;\n    gap: 20px 34px;\n  }\n\n  .mom-icon-item {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 10px;\n    width: clamp(80px, 14vw, 150px);\n  }\n\n  .mom-icon-circle {\n    width: clamp(62px, 11vw, 82px);\n    height: clamp(62px, 11vw, 82px);\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    flex-shrink: 0;\n  }\n\n  .mom-icon-circle svg {\n    width: 52%;\n    height: 52%;\n  }\n\n  .mom-ic-car    { background: #fde8e8; }\n  .mom-ic-plane  { background: #e8f0fd; }\n  .mom-ic-screen { background: #e8fdf0; }\n  .mom-ic-moon   { background: #ede8fd; }\n  .mom-ic-leaf   { background: #e8fde8; }\n  .mom-ic-gift   { background: #fde8f5; }\n\n  .mom-icon-label {\n    font-size: clamp(0.82rem, 3vw, 0.88rem);\n    font-weight: 700;\n    color: #3a3a3a;\n    line-height: 1.4;\n    text-align: center;\n  }\n\n  @media (max-width: 480px) {\n    .mom-moments-section {\n      padding-top: 0;\n    }\n\n    .mom-moments-title {\n      font-size: 1.45rem;\n      margin-bottom: 24px;\n    }\n\n    .mom-icon-item { width: calc(33.33% - 10px); }\n    .mom-moments-row { gap: 22px