     stroke=\"#5c82e0\" stroke-width=\"2.8\" stroke-linejoin=\"round\" fill=\"none\"/>\n        </svg>\n      </div>\n      <span class=\"mom-icon-label\">Easier<br>Flights</span>\n    </div>\n\n    <div class=\"mom-icon-item\">\n      <div class=\"mom-icon-circle mom-ic-screen\">\n        <svg viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <rect x=\"12\" y=\"10\" width=\"40\" height=\"32\" rx=\"4\" stroke=\"#3daa6a\" stroke-width=\"3\" fill=\"none\"/>\n          <line x1=\"22\" y1=\"48\" x2=\"42\" y2=\"48\" stroke=\"#3daa6a\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n          <line x1=\"32\" y1=\"42\" x2=\"32\" y2=\"48\" stroke=\"#3daa6a\" stroke-width=\"3\"/>\n          <rect x=\"18\" y=\"16\" width=\"28\" height=\"18\" rx=\"2\" stroke=\"#3daa6a\" stroke-width=\"2\" fill=\"none\"/>\n        </svg>\n      </div>\n      <span class=\"mom-icon-label\">Softer<br>Screen Time</span>\n    </div>\n\n    <div class=\"mom-icon-item\">\n      <div class=\"mom-icon-circle mom-ic-moon\">\n        <svg viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <path d=\"M36 10a22 22 0 100 44 16 16 0 010-44z\"\n                stroke=\"#7c5ce0\" stroke-width=\"3\" stroke-linejoin=\"round\" fill=\"none\"/>\n          <circle cx=\"44\" cy=\"14\" r=\"2.5\" fill=\"#7c5ce0\"/>\n          <circle cx=\"50\" cy=\"22\" r=\"1.8\" fill=\"#7c5ce0\"/>\n          <circle cx=\"46\" cy=\"28\" r=\"1.3\" fill=\"#7c5ce0\"/>\n        </svg>\n      </div>\n      <span class=\"mom-icon-label\">Cozy<br>Bedtime Stories</span>\n    </div>\n\n    <div class=\"mom-icon-item\">\n      <div class=\"mom-icon-circle mom-ic-leaf\">\n        <svg viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <path d=\"M32 52C32 52 12 40 12 24a20 20 0 0140 0c0 16-20 28-20 28z\"\n                stroke=\"#4da84d\" stroke-width=\"3\" stroke-linejoin=\"round\" fill=\"none\"/>\n          <line x1=\"32\" y1=\"52\" x2=\"32\" y2