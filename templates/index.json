    "custom_liquid_NUxUTh": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap\" rel=\"stylesheet\"/>\n\n<style>\n  .etu-section {\n    width: 100%;\n    max-width: 860px;\n    margin: 0 auto;\n    padding: 40px 24px 48px;\n    text-align: center;\n    font-family: 'Nunito', sans-serif;\n    background: #ffffff;\n  }\n\n  .etu-title {\n    font-size: clamp(1.5rem, 5vw, 1.9rem);\n    font-weight: 800;\n    color: #1e1e1e;\n    margin-bottom: 4px;\n  }\n\n  .etu-heart {\n    display: block;\n    margin: 0 auto 36px;\n    line-height: 1;\n  }\n\n  .etu-heart svg { width: 14px; height: 14px; }\n\n  /* Clips the sliding row */\n  .etu-slider-wrapper {\n    overflow: hidden;\n    width: 100%;\n  }\n\n  /* Row: steps + arrows */\n  .etu-row {\n    display: flex;\n    align-items: flex-start;\n    justify-content: center;\n    gap: 0;\n    flex-wrap: nowrap;\n  }\n\n  /* Each step */\n  .etu-step {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 14px;\n    flex: 1;\n    max-width: 220px;\n  }\n\n  /* Number badge */\n  .etu-badge {\n    width: 32px; height: 32px;\n    border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    font-size: 0.9rem; font-weight: 800; color: #fff;\n    flex-shrink: 0; margin-bottom: 2px;\n  }\n  .etu-badge-1 { background: #e87c7c; }\n  .etu-badge-2 { background: #5c82e0; }\n  .etu-badge-3 { background: #c8a8d8; }\n\n  /* Icon circles */\n  .etu-circle {\n    width: clamp(90px, 16vw, 120px);\n    height: clamp(90px, 16vw, 120px);\n    border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    flex-shrink: 0;\n  }\n  .etu-circle svg { width: 55%; height: 55%; }\n  .etu-circle-1 { background: #fff; border: 2px solid #e8e0d8; }\n  .etu-circle-2 { background: #fff; border: 2px solid #e8e0d8; }\n  .etu-circle-3 { background: #f0e8f0; border: 3px solid #e0d0e8; overflow: hidden; }\n  .etu-circle-3 svg { width: 70%; height: 70%; }\n\n  .etu-step-title {\n    font-size: clamp(0.95rem, 3vw, 1.05rem);\n    font-weight: 800; color: #1e1e1e; margin: 0;\n  }\n  .etu-step-desc {\n    font-size: clamp(0.75rem, 2.5vw, 0.82rem);\n    font-weight: 600; color: #777;\n    line-height: 1.5; margin: 0; max-width: 160px;\n  }\n\n  /* Arrow between steps */\n  .etu-arrow {\n    display: flex; align-items: center;\n    padding: 0 8px;\n    margin-top: clamp(60px, 10vw, 80px);\n    flex-shrink: 0;\n  }\n  .etu-arrow svg { width: clamp(28px, 5vw, 40px); height: 16px; }\n\n  /* Dots — hidden on desktop */\n  .etu-dots {\n    display: none;\n    justify-content: center;\n    gap: 8px; margin-top: 24px;\n  }\n  .etu-dot {\n    width: 8px; height: 8px; border-radius: 50%;\n    background: #ddd; border: none; padding: 0;\n    cursor: pointer;\n    transition: background 0.3s, transform 0.3s;\n  }\n  .etu-dot.active { background: #e87c7c; transform: scale(1.35); }\n\n  /* ── MOBILE ── */\n  @media (max-width: 520px) {\n    .etu-section { padding: 32px 0 40px; }\n    .etu-title, .etu-heart { padding: 0 24px; }\n\n    .etu-slider-wrapper { cursor: grab; }\n    .etu-slider-wrapper:active { cursor: grabbing; }\n\n    .etu-row {\n      flex-wrap: nowrap;\n      justify-content: flex-start;\n      transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);\n      will-change: transform;\n    }\n\n    .etu-step {\n      min-width: 100%; flex: 0 0 100%; max-width: 100%;\n      padding: 0 40px; box-sizing: border-box;\n    }\n\n    .etu-circle { width: 110px; height: 110px; }\n    .etu-step-title { font-size: 1.05rem; }\n    .etu-step-desc  { font-size: 0.85rem; max-width: 240px; }\n    .etu-arrow      { display: none; }\n    .etu-dots       { display: flex; }\n  }\n</style>\n\n<div class=\"etu-section\">\n  <h2 class=\"etu-title\">Easy To Use</h2>\n  <span class=\"etu-heart\">\n    <svg viewBox=\"0 0 24 24\" fill=\"#e87c7c\" xmlns=\"http://www.w3.org/2000/svg\">\n      <path d=\"M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5\n               2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09\n               C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5\n               c0 3.78-3.4 6.86-8.55 11.54L12 21.35z\"/>\n    </svg>\n  </span>\n\n  <div class=\"etu-slider-wrapper\" id=\"etuWrapper\">\n    <div class=\"etu-row\" id=\"etuRow\">\n\n      <!-- Step 1 -->\n      <div class=\"etu-step\">\n        <div class=\"etu-badge etu-badge-1\">1</div>\n        <div class=\"etu-circle etu-circle-1\">\n          <svg viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <rect x=\"10\" y=\"28\" width=\"44\" height=\"8\" rx=\"4\" stroke=\"#aaa\" stroke-width=\"2.5\" fill=\"#f0f0f0\"/>\n            <rect x=\"4\" y=\"24\" width=\"10\" height=\"16\" rx=\"3\" stroke=\"#aaa\" stroke-width=\"2.5\" fill=\"#e8e8e8\"/>\n            <line x1=\"7\" y1=\"30\" x2=\"7\" y2=\"34\" stroke=\"#aaa\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n            <line x1=\"11\" y1=\"30\" x2=\"11\" y2=\"34\" stroke=\"#aaa\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n            <rect x=\"50\" y=\"26\" width=\"10\" height=\"12\" rx=\"6\" stroke=\"#aaa\" stroke-width=\"2.5\" fill=\"#e8e8e8\"/>\n            <ellipse cx=\"32\" cy=\"32\" rx=\"5\" ry=\"4\" fill=\"#e0e0e0\" stroke=\"#aaa\" stroke-width=\"1.5\"/>\n          </svg>\n        </div>\n        <p class=\"etu-step-title\">Charge It</p>\n        <p class=\"etu-step-desc\">Use the included cable to charge before first use.</p>\n      </div>\n\n      <!-- Arrow 1 -->\n      <div class=\"etu-arrow\">\n        <svg viewBox=\"0 0 40 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <line x1=\"0\" y1=\"8\" x2=\"32\" y2=\"8\" stroke=\"#e0b0b0\" stroke-width=\"2\" stroke-dasharray=\"4 3\"/>\n          <polyline points=\"28,3 36,8 28,13\" stroke=\"#e0b0b0\" stroke-width=\"2\" stroke-linejoin=\"round\" fill=\"none\"/>\n        </svg>\n      </div>\n\n      <!-- Step 2 -->\n      <div class=\"etu-step\">\n        <div class=\"etu-badge etu-badge-2\">2</div>\n        <div class=\"etu-circle etu-circle-2\">\n          <svg viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <path d=\"M24 20l16 12-16 12V12l16 12-16 12\" stroke=\"#5c82e0\" stroke-width=\"3\" stroke-linejoin=\"round\" fill=\"none\"/>\n          </svg>\n        </div>\n        <p class=\"etu-step-title\">Connect It</p>\n        <p class=\"etu-step-desc\">Turn on Bluetooth and pair with your device.</p>\n      </div>\n\n      <!-- Arrow 2 -->\n      <div class=\"etu-arrow\">\n        <svg viewBox=\"0 0 40 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <line x1=\"0\" y1=\"8\" x2=\"32\" y2=\"8\" stroke=\"#c0c8e8\" stroke-width=\"2\" stroke-dasharray=\"4 3\"/>\n          <polyline points=\"28,3 36,8 28,13\" stroke=\"#c0c8e8\" stroke-width=\"2\" stroke-linejoin=\"round\" fill=\"none\"/>\n        </svg>\n      </div>\n\n      <!-- Step 3 -->\n      <div class=\"etu-step\">\n        <div class=\"etu-badge etu-badge-3\">3</div>\n        <div class=\"etu-circle etu-circle-3\">\n          <svg viewBox=\"0 0 64 64\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <circle cx=\"32\" cy=\"30\" r=\"14\" fill=\"#f5d5c5\" stroke=\"#e0b090\" stroke-width=\"1.5\"/>\n            <path d=\"M18 28 Q18 14 32 14 Q46 14 46 28\" fill=\"#5a3020\" stroke=\"none\"/>\n            <path d=\"M16 28 Q16 10 32 10 Q48 10 48 28\" stroke=\"#cc4477\" stroke-width=\"4\" stroke-linecap=\"round\" fill=\"none\"/>\n            <rect x=\"10\" y=\"26\" width=\"9\" height=\"13\" rx=\"4\" fill=\"#cc4477\" stroke=\"#aa2255\" stroke-width=\"1\"/>\n            <rect x=\"45\" y=\"26\" width=\"9\" height=\"13\" rx=\"4\" fill=\"#cc4477\" stroke=\"#aa2255\" stroke-width=\"1\"/>\n            <path d=\"M26 36 Q32 41 38 36\" stroke=\"#c07050\" stroke-width=\"1.8\" stroke-linecap=\"round\" fill=\"none\"/>\n            <circle cx=\"27\" cy=\"31\" r=\"1.5\" fill=\"#5a3020\"/>\n            <circle cx=\"37\" cy=\"31\" r=\"1.5\" fill=\"#5a3020\"/>\n          </svg>\n        </div>\n        <p class=\"etu-step-title\">Wear It &amp; Play</p>\n        <p class=\"etu-step-desc\">Place it on their head and enjoy!</p>\n      </div>\n\n    </div>\n  </div>\n\n  <!-- Dots (mobile only) -->\n  <div class=\"etu-dots\" id=\"etuDots\">\n    <button class=\"etu-dot active\" data-index=\"0\" aria-label=\"Step 1\"></button>\n    <button class=\"etu-dot\" data-index=\"1\" aria-label=\"Step 2\"></button>\n    <button class=\"etu-dot\" data-index=\"2\" aria-label=\"Step 3\"></button>\n  </div>\n</div>\n\n<script>\n(function () {\n  var wrapper = document.getElementById('etuWrapper');\n  var row     = document.getElementById('etuRow');\n  var dots    = document.querySelectorAll('#etuDots .etu-dot');\n  var steps   = row.querySelectorAll('.etu-step');\n  var current = 0;\n  var total   = steps.length;\n\n  function isMobile() { return window.innerWidth <= 520; }\n\n  function goTo(index) {\n    if (!isMobile()) return;\n    current = Math.max(0, Math.min(index, total - 1));\n    row.style.transform = 'translateX(-' + (current * wrapper.offsetWidth) + 'px)';\n    dots.forEach(function (d, i) { d.classList.toggle('active', i === current); });\n  }\n\n  /* Dot clicks */\n  dots.forEach(function (dot) {\n    dot.addEventListener('click', function () {\n      goTo(parseInt(dot.getAttribute('data-index')));\n    });\n  });\n\n  /* Touch swipe */\n  var startX = 0, startY = 0;\n  wrapper.addEventListener('touchstart', function (e) {\n    startX = e.touches[0].clientX;\n    startY = e.touches[0].clientY;\n  }, { passive: true });\n\n  wrapper.addEventListener('touchend', function (e) {\n    if (!isMobile()) return;\n    var dx = e.changedTouches[0].clientX - startX;\n    var dy = e.changedTouches[0].clientY - startY;\n    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {\n      goTo(dx < 0 ? current + 1 : current - 1);\n    }\n  }, { passive: true });\n\n  /* Reset on resize */\n  window.addEventListener('resize', function () {\n    if (!isMobile()) { row.style.transform = ''; }\n    else { goTo(current); }\n  });\n})();\n</script>",
