{% doc %}
  @prompt
    guarantees delivery all over lebanon and 24/7 support
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-guarantees-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-guarantees-container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    flex-wrap: wrap;
  }

  .ai-guarantees-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    flex: 1 1 auto;
    min-width: 200px;
  }

  .ai-guarantees-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background_color }};
    border-radius: 50%;
    padding: 8px;
  }

  .ai-guarantees-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
    fill: none;
  }

  .ai-guarantees-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-guarantees-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-guarantees-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-guarantees-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 16px;
    }

    .ai-guarantees-item-{{ ai_gen_id }} {
      width: 100%;
      min-width: unset;
    }
  }
{% endstyle %}

<div class="ai-guarantees-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-guarantees-container-{{ ai_gen_id }}">
    <div class="ai-guarantees-item-{{ ai_gen_id }}">
      <div class="ai-guarantees-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
      </div>
      <div class="ai-guarantees-content-{{ ai_gen_id }}">
        <h3 class="ai-guarantees-title-{{ ai_gen_id }}">{{ block.settings.delivery_title }}</h3>
        <p class="ai-guarantees-text-{{ ai_gen_id }}">{{ block.settings.delivery_text }}</p>
      </div>
    </div>

    <div class="ai-guarantees-item-{{ ai_gen_id }}">
      <div class="ai-guarantees-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
      </div>
      <div class="ai-guarantees-content-{{ ai_gen_id }}">
        <h3 class="ai-guarantees-title-{{ ai_gen_id }}">{{ block.settings.support_title }}</h3>
        <p class="ai-guarantees-text-{{ ai_gen_id }}">{{ block.settings.support_text }}</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Delivery guarantees",
  "settings": [
    {
      "type": "header",
      "content": "Delivery guarantee"
    },
    {
      "type": "text",
      "id": "delivery_title",
      "label": "Title",
      "default": "Lebanon delivery"
    },
    {
      "type": "text",
      "id": "delivery_text",
      "label": "Text",
      "default": "All over Lebanon"
    },
    {
      "type": "header",
      "content": "Support guarantee"
    },
    {
      "type": "text",
      "id": "support_title",
      "label": "Title",
      "default": "24/7 support"
    },
    {
      "type": "text",
      "id": "support_text",
      "label": "Text",
      "default": "Always here to help"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between items",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "item_background_color",
      "label": "Item background",
      "default": "#f7f7f7"
    },
    {
      "type": "color",
      "id": "icon_background_color",
      "label": "Icon background",
      "default": "#c79027"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title",
      "default": "#171717"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 24,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "item_border_radius",
      "label": "Item border radius",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "Delivery guarantees"
    }
  ]
}
{% endschema %}
